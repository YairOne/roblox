	local owners, seen = {}, {}
	for _, sq in ipairs(baseSquareList) do
		local ownerName = getBaseOwnerNameFromSquare(sq)
		if ownerName and not seen[ownerName] then
			seen[ownerName] = true
			table.insert(owners, ownerName)
		end
	end
	return owners
end

